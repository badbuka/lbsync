# Copy to /etc/lbsync/lbsync.env and edit. Referenced by lbsync.service.

# Modules to enable (comma-separated): certs, blob, and the disabled stubs.
MODULES=certs

# certs module
LETSENCRYPT_PATH=/etc/letsencrypt
SERVING_DIR=/etc/lbsync/live
VERIFY_CMD=nginx -t
RELOAD_CMD=nginx -s reload
RELOAD_TIMEOUT=30s

# blob module (optional): name=src:dest[:strategy], comma-separated
# BLOB_RESOURCES=blocklist=/etc/lbsync/src/blocklist.txt:/etc/nginx/blocklist.txt:mtime

# Cluster: list the OTHER nodes' memberlist host:port.
CLUSTER_PEERS=lb-02.internal:3322,lb-03.internal:3322
ADVERTISE_ADDR=lb-01.internal
CLUSTER_ENV=lan
BIND_ADDR=0.0.0.0
OLRIC_PORT=3320
MEMBERLIST_PORT=3322

# Security (mandatory unless INSECURE=true). Generate a gossip key with:
#   head -c 32 /dev/urandom | base64
CLUSTER_PASSWORD=change-me
CLUSTER_GOSSIP_KEY=

RECONCILE_INTERVAL=30s
PORT=8623
